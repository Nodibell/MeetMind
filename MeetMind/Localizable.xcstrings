    "Apple Intelligence \u0442\u0430 DeepMLX \u043d\u0435 \u043c\u0430\u044e\u0442\u044c API \u0435\u043c\u0431\u0435\u0434\u0438\u043d\u0433\u0456\u0432. \u0414\u043b\u044f RAG \u043f\u043e\u0442\u0440\u0456\u0431\u0435\u043d \u043e\u043a\u0440\u0435\u043c\u0438\u0439 Ollama \u0430\u0431\u043e LM Studio \u0441\u0435\u0440\u0432\u0435\u0440.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence and DeepMLX do not have API embeddings. A separate Ollama or LM Studio server is required for RAG."
          }
        }
      }
    },
    "DeepMLX \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0443\u0454 MLX-\u043c\u043e\u0434\u0435\u043b\u0456 \u0431\u0435\u0437\u043f\u043e\u0441\u0435\u0440\u0435\u0434\u043d\u044c\u043e \u0432 MeetMind \u0447\u0435\u0440\u0435\u0437 Apple Silicon Metal. \u041c\u043e\u0434\u0435\u043b\u044c \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u043d\u043e \u0432\u0438\u0432\u0430\u043d\u0442\u0430\u0436\u0443\u0454\u0442\u044c\u0441\u044f \u0437 \u043f\u0430\u043c'\u044f\u0442\u0456 (VRAM) \u043e\u0434\u0440\u0430\u0437\u0443 \u043f\u0456\u0441\u043b\u044f \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u043d\u044f \u0430\u043d\u0430\u043b\u0456\u0437\u0443.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DeepMLX loads MLX models directly into MeetMind via Apple Silicon Metal. The model is automatically unloaded from memory (VRAM) immediately after the analysis is complete."
          }
        }
      }
    },
